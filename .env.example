# ==============================================================================
# CONFIGURATION TEMPLATE (KREDENSIAL DEFAULT / CONTOH)
# ==============================================================================
# Petunjuk: Salin file ini menjadi '.env' (cp .env.example .env)
# lalu sesuaikan nilainya dengan kebutuhan environment Anda.
# ==============================================================================

# --- POSTGRESQL / DATABASE CONFIGURATION ---
DB_IMAGE=postgres:18
DB_CONTAINER_NAME=postgres18
DB_USER=odoo
DB_PASSWORD=odoo
DB_NAME=postgres
DB_PORT_HOST=15432

# --- ODOO CONFIGURATION ---
ODOO_IMAGE=odoo:19.0
ODOO_CONTAINER_NAME=odoo19
ODOO_PORT_HOST=8069

# --- OPENTELEMETRY / SIGNOZ CONFIGURATION ---
OTEL_SERVICE_NAME=odoo-v19-app
OTEL_EXPORTER_OTLP_ENDPOINT=http://172.17.0.1:4318/v1/traces
