# ==============================================================================
# CONFIGURATION TEMPLATE
# ==============================================================================
# Petunjuk: Salin file ini menjadi 'odoo.conf' (cp odoo.conf.example odoo.conf)
# lalu sesuaikan nilainya dengan kebutuhan environment Anda.
# ==============================================================================

[options]
addons_path = /mnt/extra-addons/custom1
data_dir = /var/lib/odoo
admin_passwd = master_password

# POSTGRESQL / DATABASE CONFIGURATION
# db_host = DB_CONTAINER_NAME
db_host = postgres18
db_port = 5432
db_user = odoo
db_password = odoo
